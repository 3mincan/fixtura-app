{
  "expo": {
    "name": "Fixtura",
    "slug": "fixtura",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/new/icon.png",
    "scheme": "fixtura",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/new/icon.png",
      "bundleIdentifier": "com.fixtura.app"
    },
    "android": {
      "package": "com.fixtura.app",
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/images/new/icon.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/new/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "headers": {
            "Cross-Origin-Embedder-Policy": "credentialless",
            "Cross-Origin-Opener-Policy": "same-origin"
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "resizeMode": "cover",
          "backgroundColor": "#FFFFFF",
          "image": "./assets/images/new/fixtura-light.png",
          "dark": {
            "backgroundColor": "#000000",
            "image": "./assets/images/new/fixtura-dark.png"
          }
        }
      ],
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
