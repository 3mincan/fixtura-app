{
  "name": "fixtura",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "engines": {
    "node": ">=20.19.4"
  },
  "volta": {
    "node": "20.19.4"
  },
  "dependencies": {
    "@expo/ui": "~56.0.18",
    "expo": "~56.0.12",
    "expo-asset": "~56.0.17",
    "expo-audio": "~56.0.12",
    "expo-constants": "~56.0.18",
    "expo-device": "~56.0.4",
    "expo-font": "~56.0.7",
    "expo-glass-effect": "~56.0.4",
    "expo-image": "~56.0.11",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.14",
    "expo-localization": "~56.0.6",
    "expo-router": "~56.2.11",
    "expo-splash-screen": "~56.0.10",
    "expo-sqlite": "~56.0.5",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.6",
    "expo-system-ui": "~56.0.5",
    "expo-web-browser": "~56.0.5",
    "lottie-react-native": "~7.3.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-google-mobile-ads": "^16.3.4",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "@types/react": "~19.2.2",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~56.0.4",
    "eas-cli": "^20.4.0",
    "expo-dev-client": "~56.0.20",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "NODE_OPTIONS=--dns-result-order=ipv4first expo start --ios --localhost",
    "start:clear": "NODE_OPTIONS=--dns-result-order=ipv4first expo start -c --ios --localhost",
    "start:device": "NODE_OPTIONS=--dns-result-order=ipv4first expo start --dev-client --lan",
    "start:metro": "NODE_OPTIONS=--dns-result-order=ipv4first expo start --localhost",
    "kill:metro": "lsof -ti:8081 | xargs kill -9 2>/dev/null || true",
    "ios:sync-native": "APP_VARIANT=development expo prebuild --platform ios --no-install && node scripts/sync-ios-privacy-info.mjs",
    "ios:sync-native:production": "APP_VARIANT=production expo prebuild --platform ios --no-install && node scripts/sync-ios-privacy-info.mjs && rm -rf ios/Pods ios/Podfile.lock && APP_VARIANT=production npx pod-install && APP_VARIANT=production node scripts/strip-ios-dev-client-artifacts.mjs",
    "ios:sync-privacy-info": "node scripts/sync-ios-privacy-info.mjs",
    "ios:verify-native": "node scripts/verify-ios-native-sync.mjs",
    "ios:verify-production": "APP_VARIANT=production node scripts/verify-ios-production-native.mjs",
    "eas:sync-release": "node scripts/materialize-eas-release.mjs",
    "eas:build:ios": "eas build --platform ios --profile production",
    "eas:build:ios:submit": "eas build --platform ios --profile production --auto-submit",
    "eas:submit:ios": "eas submit --platform ios --profile production --latest",
    "eas-build-post-install": "if [ \"$APP_VARIANT\" = \"production\" ] && [ -d ios ]; then node scripts/strip-ios-dev-client-artifacts.mjs; fi && node scripts/materialize-eas-release.mjs",
    "ios:clean": "rm -rf ios/build && rm -rf ~/Library/Developer/Xcode/DerivedData/Fixtura-* && cd ios && pod install",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "NODE_OPTIONS=--dns-result-order=ipv4first expo start --ios --localhost",
    "ios:dev": "APP_VARIANT=development expo run:ios",
    "ios:device": "expo run:ios --device --no-bundler",
    "ios:device:release": "APP_VARIANT=production expo run:ios --device --configuration Release --no-bundler",
    "dev:ios:device": "bash scripts/dev-ios-device.sh",
    "ios:install": "bash scripts/ios-install-device.sh",
    "web": "expo start --web",
    "lint": "expo lint",
    "test": "npx tsx --test src/**/*.test.ts",
    "i18n:sync": "node scripts/build-i18n-catalog.mjs",
    "i18n:materialize": "node scripts/materialize-locale-catalogs.mjs && node scripts/build-i18n-catalog.mjs",
    "splash:lottie": "node scripts/build-splash-lottie.mjs",
    "splash:lottie:normalize": "node scripts/normalize-splash-lottie.mjs",
    "icons:build": "node scripts/build-app-icons.mjs"
  },
  "private": true,
  "overrides": {
    "uuid": "^11.1.0",
    "js-yaml": "^4.1.2"
  }
}
