{
  "cli": {
    "version": ">=16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "node": "20.19.4",
      "developmentClient": true,
      "distribution": "internal",
      "environment": "development",
      "env": {
        "APP_VARIANT": "development"
      }
    },
    "preview": {
      "node": "20.19.4",
      "distribution": "internal",
      "environment": "preview",
      "autoIncrement": true,
      "env": {
        "APP_VARIANT": "production"
      },
      "install": {
        "devDependencies": false
      }
    },
    "production": {
      "node": "20.19.4",
      "distribution": "store",
      "environment": "production",
      "autoIncrement": true,
      "env": {
        "APP_VARIANT": "production"
      },
      "install": {
        "devDependencies": false
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "track": "production",
        "releaseStatus": "completed"
      },
      "ios": {
        "metadataPath": "./store.config.json",
        "ascAppId": "6785253879",
        "appleTeamId": "QFY9689V27"
      }
    }
  }
}
